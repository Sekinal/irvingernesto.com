---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projects = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const index = projects.findIndex((p) => p.id === project.id);
const next = projects[(index + 1) % projects.length];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  description: project.data.summary,
  author: { '@type': 'Person', name: SITE.name, url: SITE.url },
  ...(project.data.link ? { url: project.data.link } : {}),
};
---

<BaseLayout
  title={`${project.data.title} · ${SITE.shortName}`}
  description={project.data.summary}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-[1600px] px-5 pt-32 md:px-10 md:pt-44">
    <header class="border-line border-b pb-12 md:pb-16">
      <p class="data-label mb-6 flex flex-wrap items-center gap-x-3 gap-y-1" data-reveal>
        <a href="/#work" class="link-under">← Work</a>
        <span class="text-faint">/</span>
        <span>0{index + 1}</span>
        <span class="text-faint">/</span>
        <span>{project.data.year}</span>
      </p>
      <h1 class="display-huge text-[clamp(3rem,9vw,9rem)]" data-reveal="mask">
        {project.data.title}<span class="text-accent">.</span>
      </h1>
      <div
        class="mt-8 flex flex-col justify-between gap-8 md:flex-row md:items-end"
        data-reveal
        style="--reveal-delay: 0.15s"
      >
        <p class="text-muted max-w-xl text-lg leading-relaxed">{project.data.tagline}</p>
        <div class="flex flex-col gap-1.5">
          <span class="data-label">{project.data.role}</span>
          {
            project.data.link && (
              <a
                href={project.data.link}
                target="_blank"
                rel="noopener"
                class="link-under text-fg text-sm font-medium"
              >
                {new URL(project.data.link).host} ↗
              </a>
            )
          }
        </div>
      </div>
    </header>

    <div class="border-line grid grid-cols-2 gap-px border-b md:grid-cols-4" data-reveal>
      {
        project.data.metrics.map((metric) => (
          <div class="px-2 py-8 md:px-4 md:py-10">
            <div class="font-display text-accent text-4xl font-semibold md:text-5xl">
              {metric.value}
            </div>
            <div class="data-label mt-3 max-w-52 normal-case">{metric.label}</div>
          </div>
        ))
      }
    </div>

    <div class="grid gap-12 py-14 md:py-20 lg:grid-cols-[1fr_16rem]">
      <div
        class="prose prose-lg text-muted prose-headings:font-display prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-fg prose-strong:text-fg prose-a:text-fg prose-a:decoration-(--color-accent) prose-a:underline-offset-4 prose-li:marker:text-accent prose-blockquote:border-accent prose-blockquote:text-fg max-w-3xl"
        data-reveal
      >
        <Content />
      </div>
      <aside class="order-first lg:order-none" data-reveal>
        <div class="sticky top-24">
          <h2 class="data-label mb-4">Stack</h2>
          <ul class="flex flex-wrap gap-2">
            {
              project.data.stack.map((tech) => (
                <li class="data-label border-line rounded-full border px-3 py-1.5">{tech}</li>
              ))
            }
          </ul>
        </div>
      </aside>
    </div>
  </article>

  <a
    href={`/work/${next.id}`}
    class="group border-line hover:bg-card block border-t transition-colors duration-300"
  >
    <div class="mx-auto max-w-[1600px] px-5 py-14 md:px-10 md:py-20">
      <span class="data-label">Next project</span>
      <span class="mt-3 flex items-center justify-between gap-6">
        <span
          class="font-display group-hover:text-accent text-[clamp(2rem,6vw,4.5rem)] leading-none font-medium tracking-tight transition-colors duration-300"
        >
          {next.data.title}
        </span>
        <span
          class="border-line-strong group-hover:border-accent group-hover:bg-accent grid size-12 shrink-0 place-items-center rounded-full border transition-all duration-300 group-hover:text-white"
        >
          <svg
            class="size-5 transition-transform duration-300 group-hover:rotate-45"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M3 13 13 3M5.5 3H13v7.5"></path>
          </svg>
        </span>
      </span>
    </div>
  </a>
</BaseLayout>
