---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';
import { readingTime, readingTimeFor } from '@/lib/reading-time';
import { blogPostingLd, breadcrumbLd } from '@/lib/structured-data';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth === 2);
const rt = readingTime(post);

// Optional plain-language companion, keyed by the same id. When present, the
// page gains a Technical / Plain English toggle.
const plainEntry = await getEntry('plain', post.id);
const plain = plainEntry ? await render(plainEntry) : null;
const plainRt = plainEntry ? readingTimeFor(plainEntry.body ?? '') : null;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const url = new URL(`/blog/${post.id}`, SITE.url).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    blogPostingLd(post, url, rt),
    breadcrumbLd([
      { name: 'Writing', url: `${SITE.url}/blog` },
      { name: post.data.title, url },
    ]),
  ],
};
---

<BaseLayout
  title={`${post.data.title} · ${SITE.shortName}`}
  description={post.data.description}
  ogType="article"
  ogImage={`/og/blog/${post.id}.png`}
  publishedTime={post.data.pubDate.toISOString()}
  tags={post.data.tags}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-[1600px] px-5 pt-32 md:px-10 md:pt-44">
    <header class="mx-auto max-w-3xl">
      <p class="data-label mb-6 flex flex-wrap items-center gap-x-3 gap-y-1" data-reveal>
        <a href="/blog" class="link-under">← Writing</a>
        <span class="text-faint">/</span>
        <span>{fmt(post.data.pubDate)}</span>
        <span class="text-faint">/</span>
        <span id="post-rt" data-technical={rt.label} data-plain={plainRt?.label}>{rt.label}</span>
      </p>
      <h1
        class="font-display text-[clamp(2.25rem,5.5vw,4.5rem)] leading-[1.05] font-medium tracking-tight text-balance"
        data-reveal="mask"
      >
        {post.data.title}
      </h1>
      <p
        class="text-muted mt-6 text-lg leading-relaxed"
        data-reveal
        style="--reveal-delay: 0.1s"
      >
        {post.data.description}
      </p>
      <div class="mt-6 flex flex-wrap gap-2" data-reveal style="--reveal-delay: 0.15s">
        {
          post.data.tags.map((tag) => (
            <span class="data-label border-line rounded-full border px-2.5 py-1">{tag}</span>
          ))
        }
      </div>

      {
        plain && (
          <div
            id="mode-toggle"
            class="border-line mt-8 inline-flex gap-1 rounded-full border p-1"
            role="tablist"
            aria-label="Reading level"
            data-reveal
            style="--reveal-delay: 0.2s"
          >
            <button
              type="button"
              role="tab"
              data-mode="technical"
              aria-selected="true"
              class="mode-btn data-label rounded-full px-4 py-2 transition-colors"
            >
              Technical
            </button>
            <button
              type="button"
              role="tab"
              data-mode="plain"
              aria-selected="false"
              class="mode-btn data-label rounded-full px-4 py-2 transition-colors"
            >
              Plain English
            </button>
          </div>
        )
      }
    </header>

    <div
      class="mx-auto mt-14 grid max-w-3xl gap-12 lg:max-w-none lg:grid-cols-[1fr_minmax(0,48rem)_1fr]"
    >
      <aside class="hidden lg:block">
        <nav
          id="toc-nav"
          class="sticky top-28 ml-auto max-w-56"
          aria-label="Table of contents"
          hidden={toc.length <= 2}
        >
          <h2 class="data-label mb-4">Contents</h2>
          <ol id="toc-list" class="border-line flex flex-col gap-2.5 border-l">
            {
              toc.map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class="toc-link text-muted hover:text-fg -ml-px block border-l border-transparent pl-4 text-sm transition-colors"
                    data-slug={heading.slug}
                  >
                    {heading.text}
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
      </aside>

      <div class="min-w-0">
        <div
          id="body-technical"
          class="prose prose-lg text-muted prose-headings:font-display prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-fg prose-headings:scroll-mt-28 prose-strong:text-fg prose-code:text-fg prose-a:text-fg prose-a:decoration-(--color-accent) prose-a:underline-offset-4 prose-li:marker:text-accent prose-blockquote:border-accent prose-blockquote:text-fg prose-hr:border-line"
        >
          <Content />
        </div>
        {
          plain && (
            <div
              id="body-plain"
              hidden
              class="prose prose-lg text-muted prose-headings:font-display prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-fg prose-headings:scroll-mt-28 prose-strong:text-fg prose-code:text-fg prose-a:text-fg prose-a:decoration-(--color-accent) prose-a:underline-offset-4 prose-li:marker:text-accent prose-blockquote:border-accent prose-blockquote:text-fg prose-hr:border-line"
            >
              <plain.Content />
            </div>
          )
        }
      </div>
      <div class="hidden lg:block"></div>
    </div>

    <footer class="border-line mx-auto mt-20 max-w-3xl border-t pt-10 pb-4 lg:max-w-none">
      <a href="/blog" class="link-under data-label">← All posts</a>
    </footer>
  </article>

  <script>
    // Scroll-spy for the table of contents. Only tracks the currently visible
    // body so the plain-English toggle does not double-count headings.
    let spyObserver: IntersectionObserver | undefined;

    // Rebuild the table of contents from whichever body is visible, so the
    // plain-English version gets its own contents rather than losing the panel.
    function buildToc() {
      const nav = document.getElementById('toc-nav');
      const list = document.getElementById('toc-list');
      if (!nav || !list) return;
      const active = document.querySelector(
        '#body-technical:not([hidden]), #body-plain:not([hidden])'
      );
      const headings = active ? [...active.querySelectorAll<HTMLElement>('h2[id]')] : [];
      if (headings.length <= 2) {
        nav.hidden = true;
        return;
      }
      nav.hidden = false;
      list.replaceChildren();
      for (const h of headings) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.className =
          'toc-link text-muted hover:text-fg -ml-px block border-l border-transparent pl-4 text-sm transition-colors';
        a.dataset.slug = h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        list.appendChild(li);
      }
    }

    function buildSpy() {
      spyObserver?.disconnect();
      const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
      if (!links.length) return;
      const map = new Map<string, HTMLAnchorElement>();
      links.forEach((link) => map.set(link.dataset.slug!, link));
      const spy = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              links.forEach((l) => l.classList.remove('text-fg', 'border-accent!'));
              map.get(entry.target.id)?.classList.add('text-fg', 'border-accent!');
            }
          }
        },
        { rootMargin: '-20% 0px -70% 0px' }
      );
      const active = document.querySelector('#body-technical:not([hidden]), #body-plain:not([hidden])');
      active?.querySelectorAll('h2[id]').forEach((h) => spy.observe(h));
      spyObserver = spy;
    }

    function initToggle() {
      const toggle = document.getElementById('mode-toggle');
      const technical = document.getElementById('body-technical');
      const plain = document.getElementById('body-plain');
      const rt = document.getElementById('post-rt');
      if (!toggle || !technical || !plain) return;

      const apply = (mode: string, focus = false) => {
        const isPlain = mode === 'plain';
        plain.hidden = !isPlain;
        technical.hidden = isPlain;
        toggle.querySelectorAll<HTMLButtonElement>('.mode-btn').forEach((b) =>
          b.setAttribute('aria-selected', String(b.dataset.mode === mode))
        );
        if (rt) {
          const label = isPlain ? rt.dataset.plain : rt.dataset.technical;
          if (label) rt.textContent = label;
        }
        try {
          localStorage.setItem('read-mode', mode);
        } catch (_) {
          /* storage blocked, no persistence */
        }
        // The contents panel follows the active body's own headings.
        buildToc();
        buildSpy();
        if (focus) technical.parentElement?.scrollIntoView({ block: 'start', behavior: 'smooth' });
      };

      if (!toggle.dataset.bound) {
        toggle.dataset.bound = 'true';
        toggle.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.mode-btn');
          if (btn?.dataset.mode) apply(btn.dataset.mode, true);
        });
      }

      let stored = 'technical';
      try {
        stored = localStorage.getItem('read-mode') || 'technical';
      } catch (_) {
        /* ignore */
      }
      apply(stored);
    }

    document.addEventListener('astro:page-load', () => {
      initToggle();
      buildToc();
      buildSpy();
    });
  </script>

  <style>
    .mode-btn {
      color: var(--color-muted);
      cursor: pointer;
    }
    .mode-btn[aria-selected='true'] {
      background: var(--color-accent);
      color: #fff;
    }
    .mode-btn[aria-selected='false']:hover {
      color: var(--color-fg);
    }
  </style>
</BaseLayout>
