---
import '@/styles/global.css';
import { SEO } from 'astro-seo';
import { ClientRouter } from 'astro:transitions';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import CursorFX from '@/components/CursorFX.astro';
import { SITE } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogType = 'website',
  publishedTime,
  tags,
  jsonLd,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  alternateName: ['Irving Ernesto', 'ieqr'],
  url: SITE.url,
  email: SITE.email,
  jobTitle: 'AI Engineer & Physicist',
  worksFor: { '@type': 'Organization', name: 'RoomIQ', url: 'https://roomiq.io' },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Universidad Veracruzana' },
  knowsAbout: [
    'Machine Learning',
    'LLM Fine-tuning',
    'Data Engineering',
    'Reverse Engineering',
    'Physics',
  ],
  sameAs: [
    'https://github.com/Sekinal',
    'https://huggingface.co/Thermostatic',
    'https://x.com/ieqr_',
    'https://www.linkedin.com/in/ieqr',
  ],
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: { title, type: ogType, url: canonical, image: `${SITE.url}/og.png` },
        optional: { description, siteName: SITE.name, locale: 'en_US' },
        ...(ogType === 'article' && publishedTime
          ? { article: { publishedTime, authors: [SITE.name], tags } }
          : {}),
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: `${SITE.url}/og.png`,
      }}
      extend={{
        link: [
          { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
          { rel: 'alternate', type: 'application/rss+xml', title: SITE.name, href: '/rss.xml' },
          { rel: 'sitemap', href: '/sitemap-index.xml' },
        ],
        meta: [
          { name: 'author', content: SITE.name },
          { name: 'generator', content: Astro.generator },
        ],
      }}
    />
    <ClientRouter />
    <link
      rel="preload"
      href="/fonts/ClashDisplay-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Satoshi-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd ?? defaultJsonLd)}
      is:inline
    />
    <script is:inline>
      // Theme init: runs before paint to avoid flash, and re-applies after
      // client-side navigation swaps in a fresh <html>.
      (() => {
        const apply = () => {
          const stored = localStorage.getItem('theme');
          const system = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          document.documentElement.dataset.theme =
            stored === 'light' || stored === 'dark' ? stored : system;
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
  </head>
  <body class="min-h-svh antialiased">
    <a
      href="#main"
      class="data-label bg-accent fixed top-3 left-3 z-100 -translate-y-20 rounded px-3 py-2 text-white transition-transform focus:translate-y-0"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CursorFX />

    <script>
      // Scroll reveals + label scramble. Re-initialized on every page view
      // (astro:page-load fires on initial load and after each client-side nav).
      let observer: IntersectionObserver | undefined;
      const GLYPHS = '!<>-_\\/[]{}=+*^?#0123456789ABCDEF';
      const reduceMotion = () => matchMedia('(prefers-reduced-motion: reduce)').matches;

      function scramble(el: HTMLElement) {
        if (reduceMotion() || el.dataset.scrambled) return;
        el.dataset.scrambled = 'true';
        const original = el.textContent ?? '';
        const start = performance.now();
        const DURATION = 650;
        const step = (now: number) => {
          const progress = Math.min(1, (now - start) / DURATION);
          const settled = Math.floor(original.length * progress);
          el.textContent =
            original.slice(0, settled) +
            [...original.slice(settled)]
              .map((ch) => (ch === ' ' ? ' ' : GLYPHS[(Math.random() * GLYPHS.length) | 0]))
              .join('');
          if (progress < 1) requestAnimationFrame(step);
          else el.textContent = original;
        };
        requestAnimationFrame(step);
      }

      document.addEventListener('astro:page-load', () => {
        observer?.disconnect();
        observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const el = entry.target as HTMLElement;
                el.classList.add('is-visible');
                if (el.matches('[data-scramble]')) scramble(el);
                el.querySelectorAll<HTMLElement>('[data-scramble]').forEach(scramble);
                observer!.unobserve(el);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => observer!.observe(el));
      });
    </script>
  </body>
</html>
