---
import ThemeToggle from '@/components/ThemeToggle.astro';

const links = [
  { label: 'Work', href: '/#work' },
  { label: 'About', href: '/#about' },
  { label: 'Writing', href: '/blog' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav
    class="border-line bg-bg/70 mx-auto flex max-w-[1600px] items-center justify-between border-b px-5 py-3.5 backdrop-blur-md md:px-10"
    aria-label="Main"
  >
    <a href="/" class="font-display text-fg text-lg font-semibold tracking-tight">
      ieqr<span class="text-accent">.</span>
    </a>

    <div class="data-label hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a href={link.href} class="link-under text-fg/80 hover:text-fg transition-colors">
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3">
      <span class="data-label hidden items-center gap-2 lg:flex">
        <span class="relative flex size-2">
          <span class="bg-accent absolute inline-flex size-full animate-ping rounded-full opacity-60"
          ></span>
          <span class="bg-accent relative inline-flex size-2 rounded-full"></span>
        </span>
        Open to select projects
      </span>
      <ThemeToggle />
      <button
        id="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        class="border-line grid size-9 cursor-pointer place-items-center rounded-full border md:hidden"
      >
        <span class="nav-burger relative block h-px w-4 bg-current transition-all"></span>
      </button>
    </div>
  </nav>

  <div
    id="nav-menu"
    class="border-line bg-bg/95 hidden border-b px-5 py-6 backdrop-blur-md md:hidden"
  >
    <div class="flex flex-col gap-5">
      {
        links.map((link, i) => (
          <a
            href={link.href}
            class="font-display text-fg text-3xl font-medium tracking-tight"
            style={`--reveal-delay: ${i * 0.05}s`}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<style>
  .nav-burger::before,
  .nav-burger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transition: all 0.3s ease;
  }
  .nav-burger::before {
    top: -5px;
  }
  .nav-burger::after {
    top: 5px;
  }
  [aria-expanded='true'] .nav-burger {
    background: transparent;
  }
  [aria-expanded='true'] .nav-burger::before {
    top: 0;
    transform: rotate(45deg);
  }
  [aria-expanded='true'] .nav-burger::after {
    top: 0;
    transform: rotate(-45deg);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-menu');
    if (!toggle || !menu || toggle.dataset.bound) return;
    toggle.dataset.bound = 'true';
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('hidden', open);
    });
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'A') {
        toggle.setAttribute('aria-expanded', 'false');
        menu.classList.add('hidden');
      }
    });
  });
</script>
