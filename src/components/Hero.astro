---
import { SITE } from '@/lib/site';
---

<section id="hero" class="relative isolate flex min-h-svh flex-col justify-end overflow-hidden">
  <canvas id="field" class="pointer-events-none absolute inset-0 -z-10 size-full" aria-hidden="true"></canvas>
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 80% 60% at 50% 100%, var(--color-bg) 20%, transparent 100%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto w-full max-w-[1600px] px-5 pb-10 md:px-10 md:pb-14">
    <p class="data-label mb-6 flex flex-wrap items-center gap-x-3 gap-y-1" data-reveal>
      <span class="text-accent">●</span>
      <span data-scramble>{SITE.name}</span>
      <span class="text-faint">/</span>
      <span data-scramble>CTO @ RoomIQ</span>
      <span class="text-faint">/</span>
      <span data-scramble>{SITE.location}</span>
    </p>

    <h1
      id="hero-title"
      class="display-huge text-fg text-[clamp(3rem,10.5vw,10.5rem)]"
      data-reveal="mask"
    >
      AI engineer<span class="text-accent">,</span><br />
      physicist<span class="text-accent">.</span>
    </h1>

    <div
      class="mt-8 flex flex-col justify-between gap-8 md:flex-row md:items-end"
      data-reveal
      style="--reveal-delay: 0.2s"
    >
      <p class="text-muted max-w-md text-base leading-relaxed md:text-lg">
        I build machine-learning systems and the infrastructure that keeps them alive:
        from fine-tuned LLMs for endangered languages to data platforms moving
        <span class="text-fg">80,000 listings a day</span>.
      </p>

      <div class="flex items-center gap-6">
        <a
          href="#work"
          class="magnetic group border-line-strong hover:border-accent hover:bg-accent relative flex items-center gap-3 rounded-full border px-6 py-3 transition-colors duration-300 hover:text-white"
        >
          <span class="data-label !text-current">Selected work</span>
          <svg
            class="size-3.5 transition-transform duration-300 group-hover:translate-y-0.5"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M8 2v11M3.5 8.5 8 13l4.5-4.5"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { hostSim, palette, rgba, type SimHooks } from '@/lib/sims/host';
  import { createFluid } from '@/lib/sims/fluid';

  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)');
  const COARSE = matchMedia('(pointer: coarse)').matches;

  // Particle drift field, a nod to physics. Kept as the fallback for browsers
  // without WebGL2 float buffers. Ported into a SimHooks object with the same
  // ~110-particle connected constellation look it had before, driven now by the
  // shared host loop instead of its own rAF.
  function makeParticles(canvas: HTMLCanvasElement): SimHooks | null {
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;
    let particles: { x: number; y: number; vx: number; vy: number; r: number }[] = [];
    let w = 0;
    let h = 0;
    let dpr = 1;
    let pointerX = -9999;
    let pointerY = -9999;

    return {
      resize(width, height, ratio) {
        w = width;
        h = height;
        dpr = ratio;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const count = Math.min(110, Math.floor((w * h) / 16000));
        particles = Array.from({ length: count }, () => ({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.25,
          vy: (Math.random() - 0.5) * 0.25,
          r: Math.random() * 1.4 + 0.4,
        }));
      },
      step() {
        ctx.clearRect(0, 0, w, h);
        const color = rgba(palette().fg, 1);
        const LINK = 110;

        for (const p of particles) {
          const dx = p.x - pointerX;
          const dy = p.y - pointerY;
          const d2 = dx * dx + dy * dy;
          if (d2 < 22500 && d2 > 0.01) {
            const f = 12 / d2;
            p.vx += dx * f;
            p.vy += dy * f;
          }
          p.vx = Math.max(-0.4, Math.min(0.4, p.vx * 0.995));
          p.vy = Math.max(-0.4, Math.min(0.4, p.vy * 0.995));
          p.x = (p.x + p.vx + w) % w;
          p.y = (p.y + p.vy + h) % h;
        }

        ctx.strokeStyle = color;
        for (let i = 0; i < particles.length; i++) {
          const a = particles[i]!;
          for (let j = i + 1; j < particles.length; j++) {
            const b = particles[j]!;
            const dx = a.x - b.x;
            const dy = a.y - b.y;
            const d = Math.hypot(dx, dy);
            if (d < LINK) {
              ctx.globalAlpha = (1 - d / LINK) * 0.14;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }

        ctx.fillStyle = color;
        ctx.globalAlpha = 0.5;
        for (const p of particles) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      },
      pointerMove(x, y) {
        pointerX = x;
        pointerY = y;
      },
    };
  }

  // Mount the particle fallback onto a canvas. A canvas that ever held a webgl2
  // context can never get a 2d context, so callers hand us a fresh clone.
  function mountFallback(canvas: HTMLCanvasElement, hero: HTMLElement | null) {
    canvas.dataset.mounted = '1';
    hostSim(canvas, makeParticles, {
      maxDpr: 2,
      interactWith: hero,
    });
  }

  // Kinetic type: letters near the pointer gain variable-font weight.
  function bindKineticTitle(signal: AbortSignal) {
    const title = document.getElementById('hero-title');
    const hero = document.getElementById('hero');
    if (!title || !hero || title.dataset.split) return;
    if (reduceMotion.matches || !matchMedia('(pointer: fine)').matches) return;
    title.dataset.split = 'true';

    const walker = document.createTreeWalker(title, NodeFilter.SHOW_TEXT);
    const textNodes: Text[] = [];
    while (walker.nextNode()) textNodes.push(walker.currentNode as Text);
    for (const node of textNodes) {
      const frag = document.createDocumentFragment();
      for (const ch of node.textContent ?? '') {
        if (ch.trim() === '') {
          frag.append(ch);
          continue;
        }
        const span = document.createElement('span');
        span.className = 'kinetic-ch';
        span.textContent = ch;
        frag.append(span);
      }
      node.replaceWith(frag);
    }
    const letters = [...title.querySelectorAll<HTMLElement>('.kinetic-ch')];

    let pending = false;
    hero.addEventListener(
      'pointermove',
      (e) => {
        if (pending) return;
        pending = true;
        requestAnimationFrame(() => {
          pending = false;
          for (const letter of letters) {
            const rect = letter.getBoundingClientRect();
            const dist = Math.hypot(
              e.clientX - (rect.left + rect.width / 2),
              e.clientY - (rect.top + rect.height / 2)
            );
            const boost = Math.max(0, 1 - dist / 260);
            letter.style.setProperty('--ch-wght', String(Math.round(550 + boost * 150)));
          }
        });
      },
      { signal, passive: true }
    );
    hero.addEventListener(
      'pointerleave',
      () => letters.forEach((l) => l.style.removeProperty('--ch-wght')),
      { signal }
    );
  }

  let ctrl: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    ctrl?.abort();
    const canvas = document.getElementById('field') as HTMLCanvasElement | null;
    const hero = document.getElementById('hero') as HTMLElement | null;
    ctrl = new AbortController();
    bindKineticTitle(ctrl.signal);
    if (!canvas || canvas.dataset.mounted) return;
    canvas.dataset.mounted = '1';

    const maxDpr = COARSE ? 1 : 1.25;

    // Try the GPU fluid first. When it decides at runtime that the device is too
    // slow it calls onFail: swap the canvas for a fresh clone, because a canvas
    // that once held a webgl2 context can never return a 2d context, then mount
    // the particle fallback on the clone.
    const started = hostSim(
      canvas,
      (c) =>
        createFluid(c, {
          onFail: () => {
            const parent = c.parentElement;
            if (!parent) return;
            const clone = c.cloneNode(false) as HTMLCanvasElement;
            parent.replaceChild(clone, c);
            mountFallback(clone, hero);
          },
        }) ?? makeParticles(c),
      { maxDpr, interactWith: hero },
    );
    // hostSim returns false under reduced motion, in which case nothing runs and
    // the static page copy stands on its own, which is the intended behavior.
    void started;
  });
</script>
